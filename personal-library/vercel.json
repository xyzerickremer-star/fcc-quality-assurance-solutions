{
  "version": 2,
  "builds": [{ "src": "server.js", "use": "@vercel/node" }],
  "routes": [{ "src": "/(.*)", "dest": "server.js" }],
  "functions": {
    "server.js": {
      "includeFiles": [
        "tests/**",
        "views/**",
        "public/**",
        "components/**",
        "controllers/**",
        "routes/**",
        "assertion-analyser.js",
        "test-runner.js"
      ]
    }
  }
}
